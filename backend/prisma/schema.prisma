generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(cuid())
  email String @unique
  name  String?
}

model Message {
  id      String @id @default(cuid())
  content String
  role    String
  createdAt DateTime @default(now())
}