# ──────────────────────────────────────────────
# ICIS Backend — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://icis_user:yourpassword@localhost:5432/icis_db?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Email (Nodemailer / SendGrid SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@icis.ai
EMAIL_SUPPORT=hello@icis.ai

# Redis (optional, for rate-limiting / queue)
REDIS_URL=redis://localhost:6379

# AWS S3 (optional, for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=icis-uploads

# Logging
LOG_LEVEL=debug
